# ─────────────────────────────────────────────────────────────────────────────
# Synapse-Overlord — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is git-ignored and should NEVER be committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required for AI features (Hermes Architect, Ask Models) ──────────────────
#
# Get a free Groq API key at: https://console.groq.com/
# Supports: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768
#
GROQ_API_KEY=gsk_your_key_here

# ── LLM backend (optional) ───────────────────────────────────────────────────
#
# Default: groq  (uses GROQ_API_KEY above)
# Set to: ollama (uses a local Ollama instance at http://localhost:11434)
#
# LLM_BACKEND=ollama

# ── Model overrides (optional) ───────────────────────────────────────────────
#
# These override the default models used by the triple-consensus pipeline.
# Leave commented out to use the built-in defaults.
#
# SYNAPSE_LOGIC_MODEL=llama-3.3-70b-versatile
# SYNAPSE_AUDIT_MODEL=llama-3.1-8b-instant
# SYNAPSE_OPTIMIZE_MODEL=mixtral-8x7b-32768

# ── Logging (optional) ───────────────────────────────────────────────────────
#
# Controls the tracing-subscriber log level filter.
# Examples:
#   RUST_LOG=info                        → info level for all crates
#   RUST_LOG=synapse_overlord=debug      → debug for this crate only
#   RUST_LOG=synapse_overlord=trace      → full trace (very verbose)
#
# RUST_LOG=synapse_overlord=info
